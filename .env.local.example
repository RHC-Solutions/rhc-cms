# NextAuth — REQUIRED in production
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=                          # generate with: openssl rand -base64 32

# Initial admin seed (only used if cms-data/users.json is absent AND the
# /admin/setup wizard is bypassed; emails default to admin@<site-domain> etc.)
SEED_ADMIN_PASSWORD=                      # if unset, falls back to "admin123" with a console warning
SEED_ADMIN_EMAIL=                         # default: admin@<NEXT_PUBLIC_SITE_URL domain>
SEED_JOBS_EMAIL=                          # default: jobs@<NEXT_PUBLIC_SITE_URL domain>

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_BOOKING_URL=                  # Outlook bookwithme URL (also stored in cms-data/settings.json)
NEXT_PUBLIC_PM2_APP_NAME=                 # pm2 process name shown in setup hints; default: site-domain first label

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_PROPERTY_ID=               # numeric GA4 property ID, for admin dashboard

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# SMTP (admin form notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=admin@your-domain.com

# Telegram bots — keep separate tokens per surface so revocations are scoped
# (1) Public contact-form delivery
TELEGRAM_FORMS_BOT_TOKEN=
TELEGRAM_FORMS_CHAT_ID=
# (2) Contact route — also reused for login-attempt notifications
TELEGRAM_CONTACT_BOT_TOKEN=
TELEGRAM_CONTACT_CHAT_ID=

# WhatsApp Cloud API (contact form fallback)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_DESTINATION=                     # E.164 number that receives messages, e.g. +15551234567

# Cloudflare Turnstile (contact form anti-bot)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Aikido security scanner (admin /admin/aikido panel)
AIKIDO_API_TOKEN=                         # Public API token — generate at app.aikido.dev/settings/api
AIKIDO_IDE_TOKEN=                         # IDE-plugin token (presence acknowledged but never read here)

# IPinfo (visitor geolocation)
IPINFO_TOKEN=

# Ahrefs (SEO admin panel)
NEXT_PUBLIC_AHREFS_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Automation — daily audit + weekly dependency PRs (admin /admin/automation,
# driven by scripts/audit/*.sh). All optional; the scripts derive sane defaults
# from their own location, so a fresh clone runs with none of these set.
# ─────────────────────────────────────────────────────────────────────────────
AUDIT_SCRIPTS_DIR=                        # absolute path to scripts/audit; set when admin is embedded as a submodule (e.g. /site/vendor/admin-panel/scripts/audit)
AUDIT_REPO_DIR=                           # repo the audit runs against; default: repo root containing the scripts
AUDIT_GIT_REMOTE=                         # git remote to push fix branches to; default: origin
AUDIT_BASE_BRANCH=                        # branch PRs target; default: main
AUDIT_GH_REPO=                            # owner/repo for `gh pr create`; required to open auto-fix PRs
AUDIT_WORKTREE_DIR=                       # where isolated git worktrees are created; default: $HOME/audit-worktrees
AUDIT_REPORT_TO=                          # digest recipient; default: ADMIN_EMAIL
AUDIT_LOCAL_BASE=                         # local server base the collectors hit; default: http://localhost:3001
CLAUDE_BIN=                               # path to the headless `claude` CLI for auto-fix passes; default: $HOME/.local/bin/claude
