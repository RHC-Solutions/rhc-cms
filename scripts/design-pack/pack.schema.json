{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://admin.rhcsolutions.com/schemas/design-pack/pack.json",
  "title": "Design Pack manifest (pack.json)",
  "description": "The manifest at the root of a design pack .zip. packFormat 1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["packFormat", "name", "slug", "version"],
  "properties": {
    "packFormat": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1,
      "description": "Spec version. The panel rejects a pack whose packFormat exceeds what it supports."
    },
    "name": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "createdAt": { "type": "string" },
    "minPanelVersion": { "type": "string" },
    "contents": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "theme": { "$ref": "#/definitions/applyMode" },
        "typography": { "$ref": "#/definitions/applyMode" },
        "cookies": { "$ref": "#/definitions/applyMode" },
        "settings": { "$ref": "#/definitions/applyMode" },
        "menu": { "$ref": "#/definitions/applyMode" },
        "footer": { "$ref": "#/definitions/applyMode" },
        "pages": { "$ref": "#/definitions/applyMode" },
        "assets": { "$ref": "#/definitions/applyMode" }
      }
    },
    "tokens": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Interpolation tokens used by the pack, e.g. siteName, tagline, contactEmail, domain."
    }
  },
  "definitions": {
    "applyMode": {
      "type": "string",
      "enum": ["merge", "overwrite", "merge-design-keys", "upsert-by-slug", "copy-if-absent"]
    }
  }
}
